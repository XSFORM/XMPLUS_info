# ===== Обязательные =====
BOT_TOKEN=
OWNER_CHAT_ID=

# ===== Режим бота =====
# admin — основной бот (управление ключами, дилерами, оплатой)
# dealer — дилерский бот (только кабинет дилера, read-only БД)
BOT_MODE=admin

# Код дилера (только для BOT_MODE=dealer, должен совпадать с кодом в таблице dealers)
DEALER_NAME=main

# ===== Часовой пояс =====
TIMEZONE=Asia/Ashgabat

# ===== Планировщик уведомлений =====
CHECK_INTERVAL_MINUTES=1
PRE_NOTIFY_HOURS=3
NOTIFY_EVERY_MINUTES=180
MAX_NOTIFICATIONS=2

# ===== База данных =====
# Admin-бот (SQLite, read-write):
DATABASE_URL=sqlite+aiosqlite:///./data/data.db
# Dealer-бот (SQLite, read-only через общий volume):
# DATABASE_URL=sqlite+aiosqlite:///file:/app/data/data.db?mode=ro&uri=true
